            "value" : "隐私"
          }
        }
      }
    },
    "privacy_section_background_location_content" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snowly uses background location access exclusively during active ski tracking to record your runs. A blue indicator bar is always visible when background tracking is active. Background tracking stops when you end your session."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Under åkning använder Snowly plats i bakgrunden för att spåra hela din rutt. Data lagras bara på din enhet."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当你在滑雪时，Snowly 会在后台持续获取你的位置信息以记录完整的轨迹。这些数据仅存储在你的设备上。"
          }
        }
      }
    },
    "privacy_section_background_location_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Background Location"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bakgrundsplats"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "后台定位"
          }
        }
      }
    },
    "privacy_section_collect_content" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snowly collects the following data to provide ski tracking:\n- GPS location (latitude, longitude, altitude) during active tracking\n- Motion sensor data for activity detection (skiing vs chairlift)\n- Battery level for tracking time estimation"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snowly samlar in GPS-spår, hastighet, höjd och annan skiddata. All data lagras på din enhet och i ditt privata iCloud."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snowly 收集 GPS 轨迹、速度、海拔等滑雪数据。所有数据存储在你的设备上和你的私有 iCloud 中。"
          }
        }
      }
    },
    "privacy_section_collect_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What We Collect"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Datainsamling"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "数据采集"
          }
        }
      }
    },
    "privacy_section_rights_content" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can export all your data as JSON from Settings > Export Data. You can delete all data from Settings > Delete All Data. You can also disable iCloud for Snowly in iOS settings to stop cloud sync."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kan exportera eller radera all din data i inställningarna när som helst."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你可以随时在设置中导出或删除你的所有数据。"
          }
        }
      }
    },
    "privacy_section_rights_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Rights (GDPR)"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dina rättigheter"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的权利"
          }
        }
      }
    },
    "privacy_section_share_cards_content" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When you share a session card, the image contains aggregated statistics (speed, distance, vertical) but does not include GPS coordinates, protecting your location privacy."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Delningskort genereras lokalt på din enhet. Bilder lämnar inte enheten om du inte aktivt delar dem."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "分享卡片由你的设备本地生成。除非你主动分享，否则图片不会离开设备。"
          }
        }
      }
    },
    "privacy_section_share_cards_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Share Cards"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Delningskort"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "分享卡片"
          }
        }
      }
    },
    "privacy_section_sharing_content" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snowly does not sell your data and does not share it with advertisers or analytics providers. Cloud sync uses Apple's CloudKit infrastructure."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din data säljs aldrig eller delas med tredje part. Platsdata i gruppfunktionen delas bara med medlemmar när du aktivt väljer det."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的数据永远不会被出售或与第三方共享。Crew 功能中的位置信息仅在你主动选择时才与队友共享。"
          }
        }
      }
    },
    "privacy_section_sharing_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Third-Party Sharing"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Datadelning"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "数据共享"
          }
        }
      }
    },
    "privacy_section_storage_content" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snowly stores data locally on your device with encrypted storage (NSFileProtectionComplete). Ski sessions, gear, and profile data can sync through your private iCloud CloudKit database when iCloud is available. Device-specific settings (onboarding status and Health preference) stay local."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din data krypteras på enheten med NSFileProtectionComplete. iCloud-synkdata lagras i din privata CloudKit-behållare."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的数据在设备上使用 NSFileProtectionComplete 加密。iCloud 同步数据存储在你的私有 CloudKit 容器中。"
          }
        }
      }
    },
    "privacy_section_storage_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Where Data Is Stored"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Datalagring"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "数据存储"
          }
        }
      }
    },
