    "privacy_nav_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Privacy"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Integritet"
          }
        },
        "zh-Hans" : {
