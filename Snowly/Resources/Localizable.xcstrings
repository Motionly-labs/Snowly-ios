    "privacy_nav_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Privacy"
          }
        }
      }
    },
    "privacy_section_background_location_content" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snowly uses background location access exclusively during active ski tracking to record your runs. A blue indicator bar is always visible when background tracking is active. Background tracking stops when you end your session."
          }
        }
      }
    },
    "privacy_section_background_location_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Background Location"
          }
        }
      }
    },
    "privacy_section_collect_content" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snowly collects the following data to provide ski tracking:\n- GPS location (latitude, longitude, altitude) during active tracking\n- Motion sensor data for activity detection (skiing vs chairlift)\n- Battery level for tracking time estimation"
          }
        }
      }
    },
    "privacy_section_collect_title" : {
